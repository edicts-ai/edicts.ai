---
const problems = [
  {
    icon: '🎭',
    title: 'Hallucination',
    text: 'Agents state fiction as fact because they lack verified ground truth.',
  },
  {
    icon: '💸',
    title: 'Context cost',
    text: 'Loading full memory burns 4K+ tokens. Every session. Most of it irrelevant.',
  },
  {
    icon: '🔇',
    title: 'Memory gap',
    text: 'Too heavy for cron jobs. Too expensive for lightweight sessions. Too scattered for multi-agent.',
  },
];
---

<section class="py-20 border-t border-border-subtle">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {problems.map((p) => (
        <div class="bg-bg-surface border border-border-subtle rounded-lg p-6">
          <div class="text-3xl mb-4">{p.icon}</div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{p.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{p.text}</p>
        </div>
      ))}
    </div>
    <p class="text-center text-text-secondary mt-10 text-sm max-w-xl mx-auto">
      Edicts fills the gap between expensive memory systems and no memory at all.
    </p>
  </div>
</section>
